# Ligue Odds — Environment Variables
# Copy this file to .env and fill in your API keys.
# .env is git-ignored and should never be committed.

# football-data.org API key (free tier covers FL1 at 10 req/min)
# Get yours at: https://www.football-data.org/client/register
FOOTBALL_DATA_KEY=your_football_data_org_key_here

# Odds provider: odds_api_io or the_odds_api
ODDS_PROVIDER=odds_api_io

# odds-api.io key (free tier is request/hour based)
# Get yours at: https://odds-api.io/
ODDS_API_IO_KEY=your_odds_api_io_key_here
ODDS_API_IO_SPORT=football
# Ligue 1 slug for odds-api.io. If blank, fetch_odds.py auto-discovers it.
ODDS_API_IO_LEAGUE=france-ligue-1
# Use your account's selected/allowed bookmakers. If blank, fetch_odds.py asks
# odds-api.io for the account's selected bookmakers.
ODDS_API_IO_BOOKMAKERS=DraftKings,BetMGM BR

# The Odds API key (legacy fallback; free tier: 500 req/month)
# Get yours at: https://the-odds-api.com/
ODDS_API_KEY=your_the_odds_api_key_here

# API-Football / API-Sports enrichment key (free tier: 100 req/day)
# Used for injuries, lineups, squads, and match statistics/xG when available.
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_LEAGUE_ID=61
# Leave blank to infer the current European season.
API_FOOTBALL_SEASON=
# Free API-Football plans may lag current seasons; scripts fall back here for
# historical stats/squad enrichment when the current season is blocked.
API_FOOTBALL_FALLBACK_SEASON=2024
API_FOOTBALL_DAILY_LIMIT=100
# Reserve requests for manual checks or late matchday lineup refreshes.
API_FOOTBALL_DAILY_RESERVE=10
API_FOOTBALL_XG_FIXTURE_LIMIT=12
API_FOOTBALL_AVAILABILITY_LOOKAHEAD_DAYS=14
API_FOOTBALL_AVAILABILITY_FIXTURE_LIMIT=8
API_FOOTBALL_LINEUP_LOOKAHEAD_HOURS=36
API_FOOTBALL_SQUAD_CACHE_DAYS=30
API_FOOTBALL_REQUEST_DELAY_SEC=7
